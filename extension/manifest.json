{
  "manifest_version": 3,
  "name": "Lenexa, the Synexis AI Agent",
  "version": "0.2.3",
  "description": "Knowledge-grounded Q&A for Synexis sales reps, powered by Lenexa, the Synexis AI Agent.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Open Lenexa",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["sidePanel", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}
