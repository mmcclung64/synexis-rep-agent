# Synexis Rep Agent — Environment Variables
# Copy this file to .env and fill in all values before running anything.
# Never commit .env to git.

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=synexis-rep-agent
PINECONE_ENVIRONMENT=us-east-1-aws

# --- Voyage AI ---
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Partner Key Auth ---
# Comma-separated list of active partner keys (rotate to key management service in Phase 2)
PARTNER_KEYS=

# --- Rate Limiting ---
RATE_LIMIT_PER_HOUR=100

# --- Content Pipeline ---
# Absolute path to the source_content/ folder on this machine
SOURCE_CONTENT_PATH=~/Desktop/Claude/synexis-bot/source_content

# --- Logging ---
LOG_LEVEL=INFO
