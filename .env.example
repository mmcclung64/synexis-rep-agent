# Synexis Rep Agent — Environment Variables
# Copy this file to .env and fill in all values before running anything.
# Never commit .env to git.

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=synexis-rep-agent
PINECONE_ENVIRONMENT=us-east-1-aws

# --- Voyage AI ---
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Partner Key Auth ---
# Comma-separated list of active partner keys (rotate to key management service in Phase 2)
PARTNER_KEYS=

# --- Rate Limiting ---
RATE_LIMIT_PER_HOUR=100

# --- Content Pipeline ---
# Absolute path to the source_content/ folder on this machine
SOURCE_CONTENT_PATH=~/Desktop/Claude/synexis-bot/source_content

# --- Monitoring — Email Notifications ---
NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Monitoring — Outbreak Feed ---
# HubSpot private-app token (scopes: crm.objects.companies.read, crm.objects.contacts.read,
# crm.objects.owners.read, crm.objects.tasks.write). Leave blank to disable HubSpot task
# creation; outbreak corpus drops + marketing digest email still fire without it.
HUBSPOT_ACCESS_TOKEN=
# Recipient for the daily outbreak intelligence digest (e.g. marketing@synexis.com).
MARKETING_EMAIL=

# --- Logging ---
LOG_LEVEL=INFO
